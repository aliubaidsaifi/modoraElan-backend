PORT=5000
NODE_ENV=development

# MongoDB Atlas (free M0)
MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/modora?retryWrites=true&w=majority"

# Auth
JWT_SECRET="change_this_to_a_long_random_string"
JWT_EXPIRES_IN="7d"

# Cloudinary (free tier)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Blogger (for blog section) — Blog ID + public API key
BLOGGER_BLOG_ID="your_blog_id"
BLOGGER_API_KEY="your_google_api_key"

# CORS — your frontend URL
CLIENT_URL="http://localhost:3000"
